{
    "project_root": ".",
    "db_path": "db/news_unified.db",
    "analysis_db_path": "db/news_analysis.db",
    "legacy_db_path": "news_unified.db",
    "schema_path": "db/schema.sql",
    "analysis_report_path": "reports/analysis_snapshot_latest.json",
    "ensure_schema_on_connect": true,

    "inbox_tiktok": "inbox/tiktok",
    "inbox_documents": "inbox/documents",
    "inbox_youtube": "inbox/youtube",

    "processed_tiktok": "processed/tiktok",
    "processed_youtube": "processed/youtube",
    "processed_documents": "processed/documents",
    "processed_telegram": "processed/telegram",
    "processed_keyframes": "processed/keyframes",

    "ollama_models_dir": "",
    "ollama_base_url": "http://localhost:11434",
    "ollama_host": "http://localhost:11434",
    "ollama_model": "qwen2.5:14b",
    "ollama_embed_model": "nomic-embed-text",

    "whisper_model": "large-v3",
    "whisper_device": "cuda",
    "whisper_compute_type": "float16",

    "ocr_engine": "auto",
    "ocr_allow_fallback": true,
    "ocr_lang": "ru",

    "telegram_api_id": null,
    "telegram_api_hash": null,
    "telegram_session_dir": "config",
    "telegram_collect_interval_seconds": 300,
    "telegram_posts_per_channel": 100,

    "youtube_collect_interval_seconds": 14400,
    "youtube_format": "bestvideo[height<=720]+bestaudio/best[height<=720]",

    "watch_folder_interval_seconds": 60,

    "web_collect_interval_seconds": 86400,
    "rss_collect_interval_seconds": 1800,

    "classification_interval_seconds": 21600,
    "verification_interval_seconds": 3600,

    "ner_interval_seconds": 7200,
    "quotes_interval_seconds": 7200,
    "claims_interval_seconds": 21600,
    "claim_cluster_interval_seconds": 43200,
    "semantic_index_interval_seconds": 43200,
    "cases_interval_seconds": 86400,
    "deputies_interval_seconds": 604800,
    "deputies_html_pages": 3,
    "deputies_fetch_details": false,
    "deputies_playwright_fallback": false,
    "executive_directory_interval_seconds": 604800,
    "senators_interval_seconds": 604800,
    "profiles_enrichment_interval_seconds": 604800,
    "photo_backfill_interval_seconds": 86400,
    "photo_backfill_limit": 400,
    "anticorruption_disclosures_interval_seconds": 86400,
    "company_registry_enrichment_interval_seconds": 86400,
    "company_registry_enrichment_limit": 250,
    "company_affiliations_profile_limit": 600,
    "state_company_reports_interval_seconds": 604800,
    "restriction_corpus_interval_seconds": 86400,
    "content_dedupe_interval_seconds": 43200,
    "review_pack_export_interval_seconds": 86400,
    "review_pack_import_interval_seconds": 86400,
    "relation_rebuild_enriched_interval_seconds": 86400,
    "youtube_interval_seconds": 86400,
    "rss_interval_seconds": 3600,
    "llm_interval_seconds": 43200,
    "accountability_interval_seconds": 86400,

    "duma_api_token": null,

    "http_proxy": null,
    "https_proxy": null,

    "log_level": "INFO",
    "log_file": "app.log",

    "obsidian_export_dir": "obsidian_export_graph",
    "review_export_dir": "reports/review_packs",
    "review_import_dir": "reports/review_packs",
    "review_export_queues": [
        "content_duplicates",
        "entity_duplicates",
        "assets_affiliations",
        "restrictions_justifications"
    ],

    "runtime": {
        "daemon_enabled": true,
        "single_process_only": true
    },

    "scheduler": {
        "max_instances": 1,
        "misfire_grace_time": 900,
        "coalesce": true,
        "nightly_interval_seconds": 86400,
        "weekly_interval_seconds": 604800,
        "intervals": {}
    },

    "health": {
        "timeout_seconds": 8,
        "preflight_on_start": true
    },

    "retry": {
        "default_retry_limit": 3,
        "default_backoff_seconds": 60
    },

    "snapshot": {
        "nightly_enabled": true
    },

    "export": {
        "graph_mode_default": true,
        "copy_media": true
    },

    "graph": {
        "promotion_threshold": 0.68,
        "min_support_items": 3,
        "min_support_sources": 2,
        "min_support_domains": 2
    },

    "classifier_audit": {
        "gold_claims_target": 300,
        "gold_relations_target": 300,
        "gold_tags_target": 300,
        "min_reviewed_per_kind": 30,
        "claims_precision_threshold": 0.85,
        "relations_precision_threshold": 0.80,
        "tags_precision_threshold": 0.85,
        "claim_status_drift_threshold": 0.20,
        "relation_drift_threshold": 0.30,
        "tag_drift_threshold": 0.35,
        "strict_gate": true,
        "report_path": "reports/classifier_audit_latest.json"
    },

    "ai_sweep": {
        "key_file": "key.json",
        "default_worker_count": 12,
        "min_parallel_workers": 10,
        "max_parallel_workers": 24,
        "dead_key_threshold": 3,
        "max_units_per_run": 0,
        "provider_priority": [
            "mistral",
            "perplexity",
            "groq",
            "openrouter",
            "openai"
        ]
    }
}
